       " ", "\"\<refsAll\>\"", ",", " ", 
       RowBox[{"\"\<refsPerBin\>\"", " ", "<>", " ", 
        RowBox[{"ToString", "[", "maxRefsPerBin", "]"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sourceFiles", " ", "=", " ", 
     RowBox[{"FileNames", "[", 
      RowBox[{
       RowBox[{"\"\<*_\>\"", " ", "<>", " ", "refTag", " ", "<>", 
        " ", "\"\<_sourceRows.mx\>\""}], ",", " ", "checkpointDir"}], "]"}]}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{"binnedFiles", " ", "=", " ", 
     RowBox[{"FileNames", "[", 
      RowBox[{
       RowBox[{"\"\<*_\>\"", " ", "<>", " ", "refTag", " ", "<>", 
        " ", "\"\<_binnedRows.mx\>\""}], ",", " ", "checkpointDir"}], "]"}]}],
     ";"}], "\n", "\n", 
   RowBox[{
