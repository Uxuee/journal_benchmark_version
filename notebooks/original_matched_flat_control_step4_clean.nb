       RowBox[{"{", 
        RowBox[{
        "outputDir", ",", 
         " ", "\"\<source_vertex_diagnostics_original_control.mx\>\""}], 
        "}"}], "]"}], ",", " ", "allSourceRows"}], "]"}], ";"}], "\n", 
   RowBox[{
