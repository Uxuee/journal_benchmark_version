Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "makeFlatMatchedDataRadiusThreshold", "]"}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
   "makeFlatMatchedDataRadiusThreshold", "[", "curvedData_Association", "]"}],
    ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "name", ",", "vertices", ",", "radiusAssociation", ",", 
       "phiAssociation", ",", "radii", ",", "phis", ",", "pts", ",", 
       "coordinateAssociation", ",", "eps", ",", "graph"}], "}"}], ",", 
     RowBox[{
      RowBox[{"name", "=", 
       RowBox[{
        RowBox[{"curvedData", "[", "\"\<Name\>\"", "]"}], 
        "<>", "\"\<_matchedFlatStrictRadius\>\""}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"radiusAssociation", "=", 
       RowBox[{"curvedData", "[", "\"\<RadiusAssociation\>\"", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"phiAssociation", "=", 
       RowBox[{"curvedData", "[", "\"\<PhiAssociation\>\"", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"vertices", "=", 
       RowBox[{"Keys", "[", "radiusAssociation", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"radii", "=", 
       RowBox[{"Lookup", "[", 
        RowBox[{"radiusAssociation", ",", "vertices"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"phis", "=", 
       RowBox[{"Lookup", "[", 
        RowBox[{"phiAssociation", ",", "vertices"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"pts", "=", 
       RowBox[{"MapThread", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"#1", " ", 
             RowBox[{"Cos", "[", "#2", "]"}]}], ",", 
            RowBox[{"#1", " ", 
             RowBox[{"Sin", "[", "#2", "]"}]}], ",", "0.0"}], "}"}], "&"}], ",", 
         RowBox[{"{", 
          RowBox[{"radii", ",", "phis"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"coordinateAssociation", "=", 
       RowBox[{"AssociationThread", "[", 
        RowBox[{"vertices", "->", "pts"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"eps", "=", 
       RowBox[{"distanceMatrixRadius", "[", 
        RowBox[{"pts", ",", "kNN", ",", "epsilonFactor"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"graph", "=", 
       RowBox[{"makeGeometricGraph", "[", 
        RowBox[{"pts", ",", "eps"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<Name\>\"", "->", "name"}], ",", 
        RowBox[{"\"\<Graph\>\"", "->", "graph"}], ",", 
        RowBox[{"\"\<Points\>\"", "->", "pts"}], ",", 
        RowBox[{"\"\<RadiusAssociation\>\"", "->", "radiusAssociation"}], ",", 
        RowBox[{"\"\<PhiAssociation\>\"", "->", "phiAssociation"}], ",", 
        RowBox[{"\"\<CoordinateAssociation\>\"", "->", 
         "coordinateAssociation"}], ",", 
        RowBox[{"\"\<GraphConstruction\>\"", 
         "->", "\"\<matchedFlatStrictRadiusThreshold\>\""}], ",", 
        RowBox[{"\"\<GraphK\>\"", "->", "kNN"}], ",", 
        RowBox[{"\"\<GraphEpsilon\>\"", "->", "eps"}], ",", 
        RowBox[{"\"\<EpsilonFactor\>\"", "->", "epsilonFactor"}], ",", 
        RowBox[{"\"\<Sampling\>\"", "->", "\"\<sameRphiAsCurved\>\""}]}], 
       "|>"}]}]}], "]"}]}], ";"}]}], "Input"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"flatSchwarzschildStrict", "=", 
    RowBox[{
    "makeFlatMatchedDataRadiusThreshold", "[", "bhSchwarzschild", "]"}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"strictControlGraphSummary", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"g", "=", 
           RowBox[{"data", "[", "\"\<Graph\>\"", "]"}]}], ",", 
          RowBox[{"degs", "=", 
           RowBox[{"VertexDegree", "[", 
            RowBox[{"data", "[", "\"\<Graph\>\"", "]"}], "]"}]}]}], "}"}], ",", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<Name\>\"", "->", 
           RowBox[{"data", "[", "\"\<Name\>\"", "]"}]}], ",", 
          RowBox[{"\"\<Construction\>\"", "->", 
           RowBox[{"data", "[", "\"\<GraphConstruction\>\"", "]"}]}], ",", 
          RowBox[{"\"\<k\>\"", "->", 
           RowBox[{"data", "[", "\"\<GraphK\>\"", "]"}]}], ",", 
          RowBox[{"\"\<Epsilon\>\"", "->", 
           RowBox[{"data", "[", "\"\<GraphEpsilon\>\"", "]"}]}], ",", 
          RowBox[{"\"\<EpsilonFactor\>\"", "->", 
           RowBox[{"data", "[", "\"\<EpsilonFactor\>\"", "]"}]}], ",", 
          RowBox[{"\"\<Vertices\>\"", "->", 
           RowBox[{"VertexCount", "[", "g", "]"}]}], ",", 
          RowBox[{"\"\<Edges\>\"", "->", 
           RowBox[{"EdgeCount", "[", "g", "]"}]}], ",", 
          RowBox[{"\"\<ConnectedQ\>\"", "->", 
           RowBox[{"ConnectedGraphQ", "[", "g", "]"}]}], ",", 
          RowBox[{"\"\<MeanDegree\>\"", "->", 
           RowBox[{"N", "[", 
            RowBox[{"Mean", "[", "degs", "]"}], "]"}]}], ",", 
          RowBox[{"\"\<MinDegree\>\"", "->", 
           RowBox[{"Min", "[", "degs", "]"}]}], ",", 
          RowBox[{"\"\<MaxDegree\>\"", "->", 
           RowBox[{"Max", "[", "degs", "]"}]}], ",", 
          RowBox[{"\"\<EdgeDensity\>\"", "->", 
           RowBox[{"N", "[", 
            RowBox[{"GraphDensity", "[", "g", "]"}], "]"}]}]}], "|>"}]}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"data", ",", 
        RowBox[{"{", 
         RowBox[{
         "bhSchwarzschild", ",", "flatSchwarzschildOriginal", ",", 
          "flatSchwarzschildStrict"}], "}"}]}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Dataset", "[", "strictControlGraphSummary", "]"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Export", "[", 
   RowBox[{
    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{
      "extraDir", 
       ",", "\"\<strict_control_graph_summary_schwarzschild.csv\>\""}], "}"}],
      "]"}], ",", "strictControlGraphSummary"}], "]"}], ";"}]}], "Input"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sensitivityRG", "=", "3"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"sensitivityMaxRefsPerBin", "=", "All"}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"For", " ", "final", " ", "run"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"use", ":", "sensitivityMaxRefsPerBin"}], "=", "All"}], ";"}]}],
    "*)"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "runPairSensitivity", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"runPairSensitivity", "[", 
     RowBox[{"flatData_Association", ",", "protocolLabel_String"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"bhRows", ",", "flatRows", ",", "binnedRows", ",", "gapRows"}],
        "}"}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Running protocol: \>\"", ",", "protocolLabel"}], "]"}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"bhRows", "=", 
        RowBox[{"diagnosticsForGraphAtRG", "[", 
         RowBox[{
         "bhSchwarzschild", ",", "nRadialBins", ",", 
          "sensitivityMaxRefsPerBin", ",", "sensitivityRG"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"flatRows", "=", 
        RowBox[{"diagnosticsForGraphAtRG", "[", 
         RowBox[{
         "flatData", ",", "nRadialBins", ",", "sensitivityMaxRefsPerBin", ",",
           "sensitivityRG"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"binnedRows", "=", 
        RowBox[{"numericizeRows", "[", 
         RowBox[{"aggregateRowsByGraphAndBin", "[", 
          RowBox[{"Join", "[", 
           RowBox[{"bhRows", ",", "flatRows"}], "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"gapRows", "=", 
        RowBox[{"gapTableFromBinnedRows", "[", 
         RowBox[{"binnedRows", ",", "\"\<SchwarzschildFlamm\>\"", ",", 
          RowBox[{"flatData", "[", "\"\<Name\>\"", "]"}], ",", 
          "diagnosticsForRGSweep"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Export", "[", 
        RowBox[{
         RowBox[{"FileNameJoin", "[", 
          RowBox[{"{", 
           RowBox[{"extraDir", ",", 
            
            RowBox[{"\"\<sensitivity_binned_rows_\>\"", "<>", "protocolLabel",
              "<>", "\"\<.csv\>\""}]}], "}"}], "]"}], ",", "binnedRows"}], 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"Append", "[", 
          RowBox[{"#", ",", 
           RowBox[{"\"\<Protocol\>\"", "->", "protocolLabel"}]}], "]"}], 
         "&"}], "/@", "gapRows"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"sensitivityOriginalRows", "=", 
    RowBox[{"runPairSensitivity", "[", 
     RowBox[{
     "flatSchwarzschildOriginal", ",", "\"\<originalMatchedFlatKNN\>\""}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"sensitivityStrictRows", "=", 
    RowBox[{"runPairSensitivity", "[", 
     RowBox[{
     "flatSchwarzschildStrict", ",", "\"\<strictRadiusMatchedFlat\>\""}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"sensitivityControlTable", "=", 
    RowBox[{"Join", "[", 
     RowBox[{"sensitivityOriginalRows", ",", "sensitivityStrictRows"}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Dataset", "[", "sensitivityControlTable", "]"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Export", "[", 
    RowBox[{
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
       "extraDir", 
        ",", "\"\<control_protocol_sensitivity_table_schwarzschild.csv\>\""}],
