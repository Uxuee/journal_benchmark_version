Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "runRGSweepOne", "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"runRGSweepOne", "[", "rg_Integer", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"bhRows", ",", "flatRows", ",", "binnedRows", ",", "gapRows"}],
        "}"}], ",", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Running r_g = \>\"", ",", "rg"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"bhRows", "=", 
        RowBox[{"diagnosticsForGraphAtRG", "[", 
         RowBox[{
         "bhSchwarzschild", ",", "nRadialBins", ",", "rgSweepMaxRefsPerBin", ",",
           "rg"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"flatRows", "=", 
        RowBox[{"diagnosticsForGraphAtRG", "[", 
         RowBox[{
         "flatSchwarzschildOriginal", ",", "nRadialBins", ",", 
          "rgSweepMaxRefsPerBin", ",", "rg"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"binnedRows", "=", 
        RowBox[{"numericizeRows", "[", 
         RowBox[{"aggregateRowsByGraphAndBin", "[", 
          RowBox[{"Join", "[", 
           RowBox[{"bhRows", ",", "flatRows"}], "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"gapRows", "=", 
        RowBox[{"gapTableFromBinnedRows", "[", 
         RowBox[{
         "binnedRows", ",", "\"\<SchwarzschildFlamm\>\"", 
          ",", "\"\<SchwarzschildFlamm_matchedFlatOriginal\>\"", ",", 
          "diagnosticsForRGSweep"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Export", "[", 
        RowBox[{
         RowBox[{"FileNameJoin", "[", 
          RowBox[{"{", 
           RowBox[{"extraDir", ",", 
            RowBox[{"\"\<rg_sweep_binned_rows_rg\>\"", "<>", 
             RowBox[{"ToString", "[", "rg", "]"}], "<>", "\"\<.csv\>\""}]}], 
           "}"}], "]"}], ",", "binnedRows"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Export", "[", 
        RowBox[{
         RowBox[{"FileNameJoin", "[", 
          RowBox[{"{", 
           RowBox[{"extraDir", ",", 
            RowBox[{"\"\<rg_sweep_gap_rows_rg\>\"", "<>", 
             RowBox[{"ToString", "[", "rg", "]"}], "<>", "\"\<.csv\>\""}]}], 
           "}"}], "]"}], ",", "gapRows"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"Append", "[", 
          RowBox[{"#", ",", 
           RowBox[{"\"\<GraphShellRadius\>\"", "->", "rg"}]}], "]"}], "&"}], "/@",
         "gapRows"}]}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
