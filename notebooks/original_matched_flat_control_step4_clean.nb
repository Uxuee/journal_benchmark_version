Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "diagnosticsForGraphAtRG", ",", "getProfileFromBinnedRows", ",", 
     "correlationSafeLocal", ",", "corrWithRadiusFromBinnedRows", ",", 
     "gapTableFromBinnedRows"}], "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"diagnosticsForGraphAtRG", "[", 
     RowBox[{
     "data_Association", ",", "nBins_Integer", ",", "maxPerBin_", ",", 
      "rg_Integer"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "g", ",", "name", ",", "radiusAssociation", ",", "binAssociation", ",",
         "refs", ",", "adjacencyAssociation", ",", "rows"}], "}"}], ",", 
      RowBox[{
       RowBox[{"name", "=", 
        RowBox[{"data", "[", "\"\<Name\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"g", "=", 
        RowBox[{"data", "[", "\"\<Graph\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"radiusAssociation", "=", 
        RowBox[{"data", "[", "\"\<RadiusAssociation\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"binAssociation", "=", 
        RowBox[{"makeRadialBinAssociation", "[", 
         RowBox[{"radiusAssociation", ",", "nBins"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"refs", "=", 
        RowBox[{"selectReferenceVertices", "[", 
         RowBox[{"radiusAssociation", ",", "nBins", ",", "maxPerBin"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"adjacencyAssociation", "=", 
        RowBox[{"AssociationThread", "[", 
         RowBox[{
          RowBox[{"VertexList", "[", "g", "]"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"AdjacencyList", "[", 
             RowBox[{"g", ",", "#"}], "]"}], "&"}], "/@", 
           RowBox[{"VertexList", "[", "g", "]"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rows", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"<|", 
             RowBox[{
              RowBox[{"\"\<GraphName\>\"", "->", "name"}], ",", 
              RowBox[{"\"\<GraphConstruction\>\"", "->", 
               RowBox[{"data", "[", "\"\<GraphConstruction\>\"", "]"}]}], ",", 
              RowBox[{"\"\<SourceVertex\>\"", "->", "v"}], ",", 
              RowBox[{"\"\<Radius\>\"", "->", 
               RowBox[{"N", "[", 
                RowBox[{"radiusAssociation", "[", "v", "]"}], "]"}]}], ",", 
              RowBox[{"\"\<RadialBin\>\"", "->", 
               RowBox[{"N", "[", 
                RowBox[{"binAssociation", "[", "v", "]"}], "]"}]}]}], "|>"}], 
            ",", 
            RowBox[{"sourceDiagnostics", "[", 
             RowBox[{"g", ",", "v", ",", "adjacencyAssociation", ",", "rg"}], 
             "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"v", ",", "refs"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"numericizeRows", "[", "rows", "]"}]}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"getProfileFromBinnedRows", "[", 
     RowBox[{
     "binnedRows_List", ",", "graphName_String", ",", 
      "diagnosticKey_String"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"rows", ",", "key"}], "}"}], ",", 
      RowBox[{
       RowBox[{"key", "=", 
        RowBox[{"diagnosticKey", "<>", "\"\<_Mean\>\""}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rows", "=", 
        RowBox[{"Select", "[", 
         RowBox[{"binnedRows", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"#", "[", "\"\<GraphName\>\"", "]"}], "==", "graphName"}],
            "&"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"SortBy", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"#", "[", "\"\<RadiusMean\>\"", "]"}], ",", 
              RowBox[{"#", "[", "key", "]"}]}], "}"}], "&"}], ")"}], "/@", 
          "rows"}], ",", "First"}], "]"}]}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"correlationSafeLocal", "[", 
     RowBox[{"x_List", ",", "y_List"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "pairs", "}"}], ",", 
      RowBox[{
       RowBox[{"pairs", "=", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"Transpose", "[", 
           RowBox[{"{", 
            RowBox[{"x", ",", "y"}], "}"}], "]"}], ",", 
          RowBox[{
           RowBox[{"VectorQ", "[", 
            RowBox[{"#", ",", "NumericQ"}], "]"}], "&"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "pairs", "]"}], ">=", "3"}], ",", 
         RowBox[{"N", "[", 
          RowBox[{"Correlation", "[", 
           RowBox[{
            RowBox[{"pairs", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"pairs", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "]"}], "]"}], ",", 
         RowBox[{"Missing", "[", "\"\<TooFewPoints\>\"", "]"}]}], "]"}]}]}], 
     "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"corrWithRadiusFromBinnedRows", "[", 
     RowBox[{
     "binnedRows_List", ",", "graphName_String", ",", 
      "diagnosticKey_String"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "profile", "}"}], ",", 
      RowBox[{
       RowBox[{"profile", "=", 
        RowBox[{"getProfileFromBinnedRows", "[", 
         RowBox[{"binnedRows", ",", "graphName", ",", "diagnosticKey"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"correlationSafeLocal", "[", 
        RowBox[{
         RowBox[{"profile", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
         RowBox[{"profile", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "]"}]}]}], "]"}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gapTableFromBinnedRows", "[", 
    RowBox[{
    "binnedRows_List", ",", "bhName_String", ",", "flatName_String", ",", 
     "diagnosticKeys_List"}], "]"}], ":=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"bhCorr", "=", 
          RowBox[{"corrWithRadiusFromBinnedRows", "[", 
           RowBox[{"binnedRows", ",", "bhName", ",", "key"}], "]"}]}], ",", 
         RowBox[{"flatCorr", "=", 
          RowBox[{"corrWithRadiusFromBinnedRows", "[", 
           RowBox[{"binnedRows", ",", "flatName", ",", "key"}], "]"}]}]}], 
        "}"}], ",", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Geometry\>\"", "->", "bhName"}], ",", 
         RowBox[{"\"\<Control\>\"", "->", "flatName"}], ",", 
         RowBox[{"\"\<Diagnostic\>\"", "->", "key"}], ",", 
         RowBox[{"\"\<BHCorrR\>\"", "->", "bhCorr"}], ",", 
         RowBox[{"\"\<FlatCorrR\>\"", "->", "flatCorr"}], ",", 
         RowBox[{"\"\<Gap\>\"", "->", 
          RowBox[{"N", "[", 
           RowBox[{"bhCorr", "-", "flatCorr"}], "]"}]}], ",", 
         RowBox[{"\"\<AbsGap\>\"", "->", 
          RowBox[{"N", "[", 
           RowBox[{"Abs", "[", 
            RowBox[{"bhCorr", "-", "flatCorr"}], "]"}], "]"}]}]}], "|>"}]}], 
      "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"key", ",", "diagnosticKeys"}], "}"}]}], "]"}]}], 
  ";"}]}], "Input"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rgSweepValues", "=", 
    RowBox[{"{", 
     RowBox[{"2", ",", "3", ",", "4", ",", "5"}], "}"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rgSweepMaxRefsPerBin", "=", "20"}], ";"}], "\[IndentingNewLine]", 
