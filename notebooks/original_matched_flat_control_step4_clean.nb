        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<Name\>\"", "->", 
           RowBox[{"data", "[", "\"\<Name\>\"", "]"}]}], ",", 
          RowBox[{"\"\<Construction\>\"", "->", 
           RowBox[{"data", "[", "\"\<GraphConstruction\>\"", "]"}]}], ",", 
          RowBox[{"\"\<k\>\"", "->", 
           RowBox[{"data", "[", "\"\<GraphK\>\"", "]"}]}], ",", 
          RowBox[{"\"\<Epsilon\>\"", "->", 
           RowBox[{"data", "[", "\"\<GraphEpsilon\>\"", "]"}]}], ",", 
          RowBox[{"\"\<EpsilonFactor\>\"", "->", 
           RowBox[{"data", "[", "\"\<EpsilonFactor\>\"", "]"}]}], ",", 
          RowBox[{"\"\<Vertices\>\"", "->", 
           RowBox[{"VertexCount", "[", "g", "]"}]}], ",", 
          RowBox[{"\"\<Edges\>\"", "->", 
           RowBox[{"EdgeCount", "[", "g", "]"}]}], ",", 
          RowBox[{"\"\<ConnectedQ\>\"", "->", 
           RowBox[{"ConnectedGraphQ", "[", "g", "]"}]}], ",", 
          RowBox[{"\"\<MeanDegree\>\"", "->", 
           RowBox[{"N", "[", 
            RowBox[{"Mean", "[", "degs", "]"}], "]"}]}], ",", 
          RowBox[{"\"\<MinDegree\>\"", "->", 
           RowBox[{"Min", "[", "degs", "]"}]}], ",", 
          RowBox[{"\"\<MaxDegree\>\"", "->", 
           RowBox[{"Max", "[", "degs", "]"}]}], ",", 
          RowBox[{"\"\<EdgeDensity\>\"", "->", 
           RowBox[{"N", "[", 
            RowBox[{"GraphDensity", "[", "g", "]"}], "]"}]}]}], "|>"}]}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"data", ",", "allGraphData"}], "}"}]}], "]"}]}], ";"}], 
