     RowBox[{"Join", " ", "@@", " ", 
      RowBox[{"(", 
       RowBox[{"Import", " ", "/@", " ", "binnedFiles"}], ")"}]}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"allSourceRows", " ", "=", " ", 
     RowBox[{"numericizeRows", "[", "allSourceRows", "]"}]}], ";"}], "\n", 
   RowBox[{
