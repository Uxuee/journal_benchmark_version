Cell["2. Embedding and sampling utilities", "Section"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "\n", "  ", 
    RowBox[{
    "safeZPrime", ",", "\n", "  ", "makeZInterpolation", ",", "\n", "  ", 
     "makeRandomRPhiList", ",", "\n", "  ", "makeGridRPhiList"}], "\n", "]"}],
    ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"safeZPrime", "[", "f_", "]"}], "[", 
     RowBox[{"r_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "fr", "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"fr", " ", "=", " ", 
        RowBox[{"f", "[", "r", "]"}]}], ";", "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"NumericQ", "[", "fr", "]"}], " ", "&&", " ", 
          RowBox[{"fr", " ", ">", " ", "0"}]}], ",", "\n", "    ", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"Max", "[", 
           RowBox[{"0", ",", " ", 
            RowBox[{
             RowBox[{"1", "/", "fr"}], " ", "-", " ", "1"}]}], "]"}], "]"}], ",",
          "\n", "    ", "0"}], "\n", "  ", "]"}]}]}], "\n", "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"makeZInterpolation", "[", 
     RowBox[{"f_", ",", " ", "rmin_", ",", " ", "rmax_", ",", " ", 
      RowBox[{"nGrid_", ":", " ", "3000"}]}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "rs", ",", " ", "vals", ",", " ", "increments", ",", " ", "zs"}], 
       "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"rs", " ", "=", " ", 
        RowBox[{"N", " ", "@", " ", 
         RowBox[{"Subdivide", "[", 
          RowBox[{"rmin", ",", " ", "rmax", ",", " ", "nGrid"}], "]"}]}]}], ";",
        "\n", "  ", 
       RowBox[{"vals", " ", "=", " ", 
        RowBox[{
         RowBox[{"safeZPrime", "[", "f", "]"}], " ", "/@", " ", "rs"}]}], ";",
        "\n", "  ", 
       RowBox[{"increments", " ", "=", " ", 
        RowBox[{
         RowBox[{"Differences", "[", "rs", "]"}], " ", "*", " ", 
         RowBox[{"MovingAverage", "[", 
          RowBox[{"vals", ",", " ", "2"}], "]"}]}]}], ";", "\n", "  ", 
       RowBox[{"zs", " ", "=", " ", 
        RowBox[{"Prepend", "[", 
         RowBox[{
          RowBox[{"Accumulate", "[", "increments", "]"}], ",", " ", "0"}], 
         "]"}]}], ";", "\n", "  ", 
       RowBox[{"Interpolation", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"rs", ",", " ", "zs"}], "}"}], "]"}], ",", " ", 
         RowBox[{"InterpolationOrder", " ", "->", " ", "1"}]}], "]"}]}]}], 
     "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"makeRandomRPhiList", "[", 
     RowBox[{"n_Integer", ",", " ", "rmin_", ",", " ", "rmax_", ",", " ", 
      RowBox[{"seed_Integer", ":", " ", "1234"}]}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"rs", ",", " ", "phis"}], "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"SeedRandom", "[", "seed", "]"}], ";", "\n", "  ", 
       RowBox[{"rs", " ", "=", " ", 
        RowBox[{"RandomReal", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"rmin", ",", " ", "rmax"}], "}"}], ",", " ", "n"}], 
         "]"}]}], ";", "\n", "  ", 
       RowBox[{"phis", " ", "=", " ", 
        RowBox[{"RandomReal", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", " ", 
            RowBox[{"2", " ", "Pi"}]}], "}"}], ",", " ", "n"}], "]"}]}], ";", 
       "\n", "  ", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"rs", ",", " ", "phis"}], "}"}], "]"}]}]}], "\n", "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"makeGridRPhiList", "[", 
    RowBox[{
    "nR_Integer", ",", " ", "nPhi_Integer", ",", " ", "rmin_", ",", " ", 
     "rmax_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rs", ",", " ", "phis"}], "}"}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"rs", " ", "=", " ", 
       RowBox[{"N", " ", "@", " ", 
        RowBox[{"Subdivide", "[", 
         RowBox[{"rmin", ",", " ", "rmax", ",", " ", 
          RowBox[{"nR", " ", "-", " ", "1"}]}], "]"}]}]}], ";", "\n", "  ", 
      RowBox[{"phis", " ", "=", " ", 
       RowBox[{"N", " ", "@", " ", 
        RowBox[{"Most", "[", 
         RowBox[{"Subdivide", "[", 
          RowBox[{"0", ",", " ", 
           RowBox[{"2", " ", "Pi"}], ",", " ", "nPhi"}], "]"}], "]"}]}]}], ";",
       "\n", "  ", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"r", ",", " ", "phi"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"r", ",", " ", "rs"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"phi", ",", " ", "phis"}], "}"}]}], "]"}], ",", " ", "1"}],
        "]"}]}]}], "\n", "]"}]}], ";"}], "\n"}], "Input"],

Cell["3. Original graph-construction protocol", "Section"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "\n", "  ", 
    RowBox[{
    "distanceMatrixRadius", ",", "\n", "  ", "makeGeometricGraph", ",", "\n", 
     "  ", "makeKNNGraph", ",", "\n", "  ", "makeSurfaceDataFromRPhi", ",", 
     "\n", "  ", "makeFlatMatchedDataOriginal"}], "\n", "]"}], ";"}], "\n", 
  "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Original", " ", "radius", " ", 
     RowBox[{"rule", ":", " ", "epsilon"}]}], " ", "=", " ", 
    RowBox[{"factor", " ", "*", " ", 
     RowBox[{
      RowBox[{"Median", "[", 
       RowBox[{"k", "-", 
        RowBox[{"th", " ", "neighbor", " ", "distance"}]}], "]"}], "."}]}]}], 
   " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"distanceMatrixRadius", "[", 
     RowBox[{"pts_List", ",", " ", 
      RowBox[{"k_Integer", ":", " ", "8"}], ",", " ", 
      RowBox[{"factor_", ":", " ", "1.15"}]}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"dm", ",", " ", "sortedRows", ",", " ", "kthDistances"}], 
       "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"dm", " ", "=", " ", 
        RowBox[{"DistanceMatrix", "[", "pts", "]"}]}], ";", "\n", "  ", 
       RowBox[{"sortedRows", " ", "=", " ", 
        RowBox[{"Sort", " ", "/@", " ", "dm"}]}], ";", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"First", " ", "distance", " ", "is", " ", "zero"}], ",", " ", 
         RowBox[{
          RowBox[{"the", " ", "point", " ", "itself"}], ";", " ", 
          RowBox[{"k", "+", 
           RowBox[{"1", " ", "gives", " ", "the", " ", "k"}], "-", 
           RowBox[{"th", " ", "other", " ", 
            RowBox[{"neighbor", "."}]}]}]}]}], " ", "*)"}], "\n", "  ", 
       RowBox[{"kthDistances", " ", "=", " ", 
        RowBox[{"sortedRows", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", 
           RowBox[{"Min", "[", 
            RowBox[{
             RowBox[{"k", " ", "+", " ", "1"}], ",", " ", 
             RowBox[{"Length", "[", "pts", "]"}]}], "]"}]}], "]"}], "]"}]}], ";",
        "\n", "  ", 
       RowBox[{"N", "[", 
        RowBox[{"factor", " ", "*", " ", 
         RowBox[{"Median", "[", "kthDistances", "]"}]}], "]"}]}]}], "\n", 
     "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"makeGeometricGraph", "[", 
     RowBox[{"pts_List", ",", " ", 
      RowBox[{"eps_", "?", "NumericQ"}]}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"n", ",", " ", "dm", ",", " ", "edges"}], "}"}], ",", "\n", 
      "  ", 
      RowBox[{
       RowBox[{"n", " ", "=", " ", 
        RowBox[{"Length", "[", "pts", "]"}]}], ";", "\n", "  ", 
       RowBox[{"dm", " ", "=", " ", 
        RowBox[{"DistanceMatrix", "[", "pts", "]"}]}], ";", "\n", "  ", 
       RowBox[{"edges", " ", "=", " ", 
        RowBox[{"Flatten", "[", "\n", "    ", 
         RowBox[{
          RowBox[{"Table", "[", "\n", "      ", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"i", " ", "<", " ", "j"}], " ", "&&", " ", 
               RowBox[{
                RowBox[{"dm", "[", 
                 RowBox[{"[", 
                  RowBox[{"i", ",", " ", "j"}], "]"}], "]"}], " ", "<=", " ", 
                "eps"}]}], ",", "\n", "        ", 
              RowBox[{"UndirectedEdge", "[", 
               RowBox[{"i", ",", " ", "j"}], "]"}], ",", "\n", "        ", 
              "Nothing"}], "\n", "      ", "]"}], ",", "\n", "      ", 
            RowBox[{"{", 
             RowBox[{"i", ",", " ", "n"}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"j", ",", " ", "n"}], "}"}]}], "\n", "    ", "]"}], ",", 
          "\n", "    ", "1"}], "\n", "  ", "]"}]}], ";", "\n", "  ", 
       RowBox[{"SimpleGraph", "[", 
        RowBox[{"Graph", "[", 
         RowBox[{
          RowBox[{"Range", "[", "n", "]"}], ",", " ", "edges"}], "]"}], 
        "]"}]}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"makeKNNGraph", "[", 
     RowBox[{"pts_List", ",", " ", "k_Integer"}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "n", ",", " ", "nf", ",", " ", "pairs", ",", " ", "sortedPairs", ",", 
        " ", "edges"}], "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"n", " ", "=", " ", 
        RowBox[{"Length", "[", "pts", "]"}]}], ";", "\n", "  ", 
       RowBox[{"nf", " ", "=", " ", 
        RowBox[{"Nearest", "[", 
         RowBox[{"pts", " ", "->", " ", 
          RowBox[{"Range", "[", "n", "]"}]}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"pairs", " ", "=", " ", 
        RowBox[{"Flatten", "[", "\n", "    ", 
         RowBox[{
          RowBox[{"Table", "[", "\n", "      ", 
           RowBox[{
            RowBox[{"Thread", "[", 
             RowBox[{"i", " ", "->", " ", 
              RowBox[{"DeleteCases", "[", 
               RowBox[{
                RowBox[{"nf", "[", 
                 RowBox[{
                  RowBox[{"pts", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
                  RowBox[{"k", " ", "+", " ", "1"}]}], "]"}], ",", " ", "i"}],
                "]"}]}], "]"}], ",", "\n", "      ", 
            RowBox[{"{", 
             RowBox[{"i", ",", " ", "n"}], "}"}]}], "\n", "    ", "]"}], ",", 
          "\n", "    ", "1"}], "\n", "  ", "]"}]}], ";", "\n", "  ", 
       RowBox[{"sortedPairs", " ", "=", " ", 
        RowBox[{"Sort", " ", "/@", " ", 
         RowBox[{"(", 
          RowBox[{"List", " ", "@@@", " ", "pairs"}], ")"}]}]}], ";", "\n", 
       "  ", 
       RowBox[{"edges", " ", "=", " ", 
        RowBox[{"DeleteDuplicates", "[", 
         RowBox[{"UndirectedEdge", " ", "@@@", " ", "sortedPairs"}], "]"}]}], 
       ";", "\n", "  ", 
       RowBox[{"SimpleGraph", "[", 
        RowBox[{"Graph", "[", 
         RowBox[{
          RowBox[{"Range", "[", "n", "]"}], ",", " ", "edges"}], "]"}], 
        "]"}]}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"makeSurfaceDataFromRPhi", "[", 
     RowBox[{"name_String", ",", " ", "f_", ",", " ", "rPhiList_List"}], 
     "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "zfun", ",", " ", "pts", ",", " ", "vertices", ",", " ", 
        "radiusAssociation", ",", " ", "phiAssociation", ",", "\n", "   ", 
        "coordinateAssociation", ",", " ", "eps", ",", " ", "graph"}], "}"}], 
      ",", "\n", "\n", "  ", 
      RowBox[{
       RowBox[{"zfun", " ", "=", " ", 
        RowBox[{"makeZInterpolation", "[", 
         RowBox[{"f", ",", " ", "rMin", ",", " ", "rMax"}], "]"}]}], ";", 
       "\n", "\n", "  ", 
       RowBox[{"pts", " ", "=", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}], " ", 
              RowBox[{"Cos", "[", 
               RowBox[{"#", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ",", " ", 
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}], " ", 
              RowBox[{"Sin", "[", 
               RowBox[{"#", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ",", " ", 
             RowBox[{"zfun", "[", 
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "}"}], " ", "&"}], 
          ")"}], " ", "/@", " ", "rPhiList"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"vertices", " ", "=", " ", 
        RowBox[{"Range", "[", 
         RowBox[{"Length", "[", "pts", "]"}], "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"radiusAssociation", " ", "=", " ", 
        RowBox[{"AssociationThread", "[", 
         RowBox[{"vertices", " ", "->", " ", 
          RowBox[{"N", "[", 
           RowBox[{"rPhiList", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], "]"}]}], "]"}]}], ";",
        "\n", "  ", 
       RowBox[{"phiAssociation", " ", "=", " ", 
        RowBox[{"AssociationThread", "[", 
         RowBox[{"vertices", " ", "->", " ", 
          RowBox[{"N", "[", 
           RowBox[{"rPhiList", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], "]"}]}], "]"}]}], ";",
        "\n", "  ", 
       RowBox[{"coordinateAssociation", " ", "=", " ", 
        RowBox[{"AssociationThread", "[", 
         RowBox[{"vertices", " ", "->", " ", "pts"}], "]"}]}], ";", "\n", 
       "\n", "  ", 
       RowBox[{"eps", " ", "=", " ", 
        RowBox[{"distanceMatrixRadius", "[", 
         RowBox[{"pts", ",", " ", "kNN", ",", " ", "epsilonFactor"}], "]"}]}],
        ";", "\n", "  ", 
       RowBox[{"graph", " ", "=", " ", 
        RowBox[{"makeGeometricGraph", "[", 
         RowBox[{"pts", ",", " ", "eps"}], "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"<|", "\n", "    ", 
        RowBox[{
         RowBox[{"\"\<Name\>\"", " ", "->", " ", "name"}], ",", "\n", "    ", 
         RowBox[{"\"\<Graph\>\"", " ", "->", " ", "graph"}], ",", "\n", 
         "    ", 
         RowBox[{"\"\<Points\>\"", " ", "->", " ", "pts"}], ",", "\n", "    ", 
         RowBox[{"\"\<RadiusAssociation\>\"", " ", "->", " ", 
          "radiusAssociation"}], ",", "\n", "    ", 
         RowBox[{"\"\<PhiAssociation\>\"", " ", "->", " ", "phiAssociation"}],
          ",", "\n", "    ", 
         RowBox[{"\"\<CoordinateAssociation\>\"", " ", "->", " ", 
          "coordinateAssociation"}], ",", "\n", "    ", 
         RowBox[{"\"\<GraphConstruction\>\"", " ", "->", 
          " ", "\"\<radiusThresholdOriginal\>\""}], ",", "\n", "    ", 
         RowBox[{"\"\<GraphK\>\"", " ", "->", " ", "kNN"}], ",", "\n", "    ", 
         RowBox[{"\"\<GraphEpsilon\>\"", " ", "->", " ", "eps"}], ",", "\n", 
         "    ", 
         RowBox[{"\"\<EpsilonFactor\>\"", " ", "->", " ", "epsilonFactor"}], ",",
          "\n", "    ", 
         RowBox[{"\"\<Sampling\>\"", " ", "->", 
          " ", "\"\<sharedRandomPolar\>\""}]}], "\n", "  ", "|>"}]}]}], "\n", 
     "]"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Original", " ", "matched"}], "-", 
     RowBox[{"flat", " ", 
      RowBox[{"convention", ":", " ", 
       RowBox[{
       "project", " ", "same", " ", "sample", " ", "to", " ", "z"}]}]}]}], "=", 
    RowBox[{"0", " ", "and", " ", "use", " ", "direct", " ", 
     RowBox[{"kNN", "."}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
   "makeFlatMatchedDataOriginal", "[", "curvedData_Association", "]"}], " ", ":=",
    " ", 
   RowBox[{"Module", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "name", ",", " ", "vertices", ",", " ", "radiusAssociation", ",", " ", 
       "phiAssociation", ",", "\n", "   ", "radii", ",", " ", "phis", ",", 
       " ", "pts", ",", " ", "coordinateAssociation", ",", " ", "graph"}], 
      "}"}], ",", "\n", "\n", "  ", 
     RowBox[{
      RowBox[{"name", " ", "=", " ", 
       RowBox[{
        RowBox[{"curvedData", "[", "\"\<Name\>\"", "]"}], " ", "<>", 
        " ", "\"\<_matchedFlatOriginal\>\""}]}], ";", "\n", "\n", "  ", 
      RowBox[{"radiusAssociation", " ", "=", " ", 
       RowBox[{"curvedData", "[", "\"\<RadiusAssociation\>\"", "]"}]}], ";", 
      "\n", "  ", 
      RowBox[{"phiAssociation", " ", "=", " ", 
       RowBox[{"curvedData", "[", "\"\<PhiAssociation\>\"", "]"}]}], ";", 
      "\n", "  ", 
      RowBox[{"vertices", " ", "=", " ", 
       RowBox[{"Keys", "[", "radiusAssociation", "]"}]}], ";", "\n", "\n", 
      "  ", 
      RowBox[{"radii", " ", "=", " ", 
       RowBox[{"Lookup", "[", 
        RowBox[{"radiusAssociation", ",", " ", "vertices"}], "]"}]}], ";", 
      "\n", "  ", 
      RowBox[{"phis", " ", "=", " ", 
       RowBox[{"Lookup", "[", 
        RowBox[{"phiAssociation", ",", " ", "vertices"}], "]"}]}], ";", "\n", 
      "\n", "  ", 
      RowBox[{"pts", " ", "=", " ", 
       RowBox[{"MapThread", "[", "\n", "    ", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"#1", " ", 
             RowBox[{"Cos", "[", "#2", "]"}]}], ",", " ", 
            RowBox[{"#1", " ", 
             RowBox[{"Sin", "[", "#2", "]"}]}], ",", " ", "0.0"}], "}"}], " ",
           "&"}], ",", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{"radii", ",", " ", "phis"}], "}"}]}], "\n", "  ", "]"}]}], ";",
       "\n", "\n", "  ", 
      RowBox[{"coordinateAssociation", " ", "=", " ", 
       RowBox[{"AssociationThread", "[", 
        RowBox[{"vertices", " ", "->", " ", "pts"}], "]"}]}], ";", "\n", "  ", 
      RowBox[{"graph", " ", "=", " ", 
       RowBox[{"makeKNNGraph", "[", 
        RowBox[{"pts", ",", " ", "kNN"}], "]"}]}], ";", "\n", "\n", "  ", 
      RowBox[{"<|", "\n", "    ", 
       RowBox[{
        RowBox[{"\"\<Name\>\"", " ", "->", " ", "name"}], ",", "\n", "    ", 
        RowBox[{"\"\<Graph\>\"", " ", "->", " ", "graph"}], ",", "\n", "    ", 
        RowBox[{"\"\<Points\>\"", " ", "->", " ", "pts"}], ",", "\n", "    ", 
        RowBox[{"\"\<RadiusAssociation\>\"", " ", "->", " ", 
         "radiusAssociation"}], ",", "\n", "    ", 
        RowBox[{"\"\<PhiAssociation\>\"", " ", "->", " ", "phiAssociation"}], 
        ",", "\n", "    ", 
        RowBox[{"\"\<CoordinateAssociation\>\"", " ", "->", " ", 
         "coordinateAssociation"}], ",", "\n", "    ", 
        RowBox[{"\"\<GraphConstruction\>\"", " ", "->", 
         " ", "\"\<matchedFlatOriginalKNN\>\""}], ",", "\n", "    ", 
        RowBox[{"\"\<GraphK\>\"", " ", "->", " ", "kNN"}], ",", "\n", "    ", 
        RowBox[{"\"\<GraphEpsilon\>\"", " ", "->", " ", 
         RowBox[{"Missing", "[", "\"\<NotUsed\>\"", "]"}]}], ",", "\n", 
        "    ", 
        RowBox[{"\"\<EpsilonFactor\>\"", " ", "->", " ", 
         RowBox[{"Missing", "[", "\"\<NotUsed\>\"", "]"}]}], ",", "\n", 
        "    ", 
        RowBox[{"\"\<Sampling\>\"", " ", "->", 
         " ", "\"\<sameRphiAsCurved\>\""}]}], "\n", "  ", "|>"}]}]}], "\n", 
    "]"}]}], ";"}], "\n"}], "Input"],

Cell["4. Build curved graphs and original matched-flat controls", "Section"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"baseRPhiList", " ", "=", " ", 
    RowBox[{"makeRandomRPhiList", "[", 
     RowBox[{
     "nSamples", ",", " ", "rMin", ",", " ", "rMax", ",", " ", "randomSeed"}],
      "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"curvedGraphData", " ", "=", " ", 
    RowBox[{"{", "\n", "  ", 
     RowBox[{
      RowBox[{"makeSurfaceDataFromRPhi", "[", 
       RowBox[{"\"\<SchwarzschildFlamm\>\"", ",", " ", "fSchwarzschild", ",", 
        " ", "baseRPhiList"}], "]"}], ",", "\n", "  ", 
      RowBox[{"makeSurfaceDataFromRPhi", "[", 
       RowBox[{"\"\<ReissnerNordstrom\>\"", ",", " ", "fRN", ",", " ", 
        "baseRPhiList"}], "]"}], ",", "\n", "  ", 
      RowBox[{"makeSurfaceDataFromRPhi", "[", 
       RowBox[{"\"\<Bardeen\>\"", ",", " ", "fBardeen", ",", " ", 
        "baseRPhiList"}], "]"}], ",", "\n", "  ", 
      RowBox[{"makeSurfaceDataFromRPhi", "[", 
       RowBox[{"\"\<Hayward\>\"", ",", " ", "fHayward", ",", " ", 
        "baseRPhiList"}], "]"}]}], "\n", "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"flatGraphData", " ", "=", " ", 
    RowBox[{
    "makeFlatMatchedDataOriginal", " ", "/@", " ", "curvedGraphData"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"allGraphData", " ", "=", " ", 
    RowBox[{"Join", "[", 
     RowBox[{"curvedGraphData", ",", " ", "flatGraphData"}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"graphSummary", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"<|", "\n", "    ", 
       RowBox[{
        RowBox[{"\"\<Name\>\"", " ", "->", " ", 
         RowBox[{"#", "[", "\"\<Name\>\"", "]"}]}], ",", "\n", "    ", 
        RowBox[{"\"\<Construction\>\"", " ", "->", " ", 
         RowBox[{"#", "[", "\"\<GraphConstruction\>\"", "]"}]}], ",", "\n", 
        "    ", 
        RowBox[{"\"\<k\>\"", " ", "->", " ", 
         RowBox[{"#", "[", "\"\<GraphK\>\"", "]"}]}], ",", "\n", "    ", 
        RowBox[{"\"\<Epsilon\>\"", " ", "->", " ", 
         RowBox[{"#", "[", "\"\<GraphEpsilon\>\"", "]"}]}], ",", "\n", "    ", 
        RowBox[{"\"\<EpsilonFactor\>\"", " ", "->", " ", 
         RowBox[{"#", "[", "\"\<EpsilonFactor\>\"", "]"}]}], ",", "\n", 
        "    ", 
        RowBox[{"\"\<Vertices\>\"", " ", "->", " ", 
         RowBox[{"VertexCount", "[", 
          RowBox[{"#", "[", "\"\<Graph\>\"", "]"}], "]"}]}], ",", "\n", 
        "    ", 
        RowBox[{"\"\<Edges\>\"", " ", "->", " ", 
         RowBox[{"EdgeCount", "[", 
          RowBox[{"#", "[", "\"\<Graph\>\"", "]"}], "]"}]}], ",", "\n", 
        "    ", 
        RowBox[{"\"\<ConnectedQ\>\"", " ", "->", " ", 
         RowBox[{"ConnectedGraphQ", "[", 
          RowBox[{"#", "[", "\"\<Graph\>\"", "]"}], "]"}]}]}], "\n", "  ", 
       "|>"}], " ", "&"}], " ", "/@", " ", "allGraphData"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"Export", "[", 
   RowBox[{
    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{
      "outputDir", ",", " ", "\"\<graph_summary_original_control.csv\>\""}], 
      "}"}], "]"}], ",", " ", "graphSummary"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Export", "[", 
    RowBox[{
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
       "outputDir", ",", " ", "\"\<graph_summary_original_control.mx\>\""}], 
       "}"}], "]"}], ",", " ", "graphSummary"}], "]"}], ";"}], "\n"}], "\n", 
 RowBox[{"Dataset", "[", "graphSummary", "]"}], "\n"}], "Input"],

Cell["5. Radial bins and reference vertices", "Section"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "\n", "  ", 
    RowBox[{
    "makeRadialBinAssociation", ",", "\n", "  ", "selectReferenceVertices"}], 
    "\n", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"makeRadialBinAssociation", "[", 
     RowBox[{"radiusAssociation_Association", ",", " ", "nBins_Integer"}], 
     "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "vertices", ",", " ", "radii", ",", " ", "rlo", ",", " ", "rhi"}], 
       "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"vertices", " ", "=", " ", 
        RowBox[{"Keys", "[", "radiusAssociation", "]"}]}], ";", "\n", "  ", 
       RowBox[{"radii", " ", "=", " ", 
        RowBox[{"Values", "[", "radiusAssociation", "]"}]}], ";", "\n", "  ", 
       RowBox[{"rlo", " ", "=", " ", 
        RowBox[{"Min", "[", "radii", "]"}]}], ";", "\n", "  ", 
       RowBox[{"rhi", " ", "=", " ", 
        RowBox[{"Max", "[", "radii", "]"}]}], ";", "\n", "  ", 
       RowBox[{"AssociationThread", "[", "\n", "    ", 
        RowBox[{"vertices", " ", "->", "\n", "      ", 
         RowBox[{"(", "\n", "        ", 
          RowBox[{
           RowBox[{
            RowBox[{"Clip", "[", "\n", "          ", 
             RowBox[{
              RowBox[{"1", " ", "+", " ", 
               RowBox[{"Floor", "[", 
                RowBox[{"nBins", " ", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"Lookup", "[", 
                    RowBox[{"radiusAssociation", ",", " ", "#"}], "]"}], " ", 
                    "-", " ", "rlo"}], ")"}], "/", 
                  RowBox[{"(", 
                   RowBox[{"rhi", " ", "-", " ", "rlo"}], ")"}]}]}], "]"}]}], 
              ",", "\n", "          ", 
              RowBox[{"{", 
               RowBox[{"1", ",", " ", "nBins"}], "}"}]}], "\n", "        ", 
             "]"}], " ", "&"}], " ", "/@", " ", "vertices"}], "\n", "      ", 
          ")"}]}], "\n", "  ", "]"}]}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"selectReferenceVertices", "[", 
    RowBox[{
    "radiusAssociation_Association", ",", " ", "nBins_Integer", ",", " ", 
     RowBox[{"maxPerBin_", ":", " ", "All"}]}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"binAssociation", ",", " ", "vertices", ",", " ", "grouped"}], 
      "}"}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"vertices", " ", "=", " ", 
       RowBox[{"Keys", "[", "radiusAssociation", "]"}]}], ";", "\n", "  ", 
      RowBox[{"binAssociation", " ", "=", " ", 
       RowBox[{"makeRadialBinAssociation", "[", 
        RowBox[{"radiusAssociation", ",", " ", "nBins"}], "]"}]}], ";", "\n", 
      "  ", 
      RowBox[{"grouped", " ", "=", " ", 
       RowBox[{"GroupBy", "[", 
        RowBox[{"vertices", ",", " ", 
         RowBox[{
          RowBox[{"binAssociation", "[", "#", "]"}], " ", "&"}]}], "]"}]}], ";",
       "\n", "  ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"maxPerBin", " ", "===", " ", "All"}], ",", "\n", "    ", 
        RowBox[{"Flatten", "[", 
         RowBox[{"Values", "[", "grouped", "]"}], "]"}], ",", "\n", "    ", 
        RowBox[{
         RowBox[{"SeedRandom", "[", "1234", "]"}], ";", "\n", "    ", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"RandomSample", "[", 
             RowBox[{"#", ",", " ", 
              RowBox[{"Min", "[", 
               RowBox[{
                RowBox[{"Length", "[", "#", "]"}], ",", " ", "maxPerBin"}], 
               "]"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
           RowBox[{"Values", "[", "grouped", "]"}]}], "]"}]}]}], "\n", "  ", 
       "]"}]}]}], "\n", "]"}]}], ";"}], "\n"}], "Input"],

Cell["6. Shortest-path multiplicity diagnostics", "Section"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "\n", "  ", 
    RowBox[{
    "localClusteringCoefficient", ",", "\n", "  ", 
     "shortestPathCountsFromSource", ",", "\n", "  ", "sourceDiagnostics", ",",
      "\n", "  ", "diagnosticsForGraph"}], "\n", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"localClusteringCoefficient", "[", 
     RowBox[{"g_Graph", ",", " ", "v_"}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "neighbors", ",", " ", "d", ",", " ", "neighborPairs", ",", " ", 
        "existingEdges"}], "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"neighbors", " ", "=", " ", 
        RowBox[{"AdjacencyList", "[", 
         RowBox[{"g", ",", " ", "v"}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"d", " ", "=", " ", 
        RowBox[{"Length", "[", "neighbors", "]"}]}], ";", "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"d", " ", "<", " ", "2"}], ",", " ", 
         RowBox[{"Return", "[", "0.", "]"}]}], "]"}], ";", "\n", "  ", 
       RowBox[{"neighborPairs", " ", "=", " ", 
        RowBox[{"Subsets", "[", 
         RowBox[{"neighbors", ",", " ", 
          RowBox[{"{", "2", "}"}]}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"existingEdges", " ", "=", " ", 
        RowBox[{"Count", "[", 
         RowBox[{"neighborPairs", ",", " ", 
          RowBox[{"pair_", " ", "/;", " ", 
           RowBox[{"EdgeQ", "[", 
            RowBox[{"g", ",", " ", 
             RowBox[{"UndirectedEdge", " ", "@@", " ", "pair"}]}], "]"}]}]}], 
         "]"}]}], ";", "\n", "  ", 
       RowBox[{"N", "[", 
        RowBox[{"2", " ", 
         RowBox[{"existingEdges", "/", 
          RowBox[{"(", 
           RowBox[{"d", " ", 
            RowBox[{"(", 
             RowBox[{"d", " ", "-", " ", "1"}], ")"}]}], ")"}]}]}], "]"}]}]}],
      "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"shortestPathCountsFromSource", "[", 
     RowBox[{
     "g_Graph", ",", " ", "source_", ",", " ", 
      "adjacencyAssociation_Association"}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "vertices", ",", " ", "distances", ",", " ", "reachable", ",", " ", 
        "ordered", ",", " ", "sigma", ",", " ", "predecessors"}], "}"}], ",", 
      "\n", "\n", "  ", 
      RowBox[{
       RowBox[{"vertices", " ", "=", " ", 
        RowBox[{"VertexList", "[", "g", "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"distances", " ", "=", " ", 
        RowBox[{"AssociationThread", "[", "\n", "    ", 
         RowBox[{"vertices", ",", "\n", "    ", 
          RowBox[{
           RowBox[{
            RowBox[{"GraphDistance", "[", 
             RowBox[{"g", ",", " ", "source", ",", " ", "#"}], "]"}], " ", 
            "&"}], " ", "/@", " ", "vertices"}]}], "\n", "  ", "]"}]}], ";", 
       "\n", "\n", "  ", 
       RowBox[{"reachable", " ", "=", " ", 
        RowBox[{"Select", "[", "\n", "    ", 
         RowBox[{"vertices", ",", "\n", "    ", 
          RowBox[{
           RowBox[{
            RowBox[{"NumericQ", "[", 
             RowBox[{"distances", "[", "#", "]"}], "]"}], " ", "&&", " ", 
            RowBox[{
             RowBox[{"distances", "[", "#", "]"}], " ", "<", " ", 
             "Infinity"}]}], " ", "&"}]}], "\n", "  ", "]"}]}], ";", "\n", 
       "\n", "  ", 
       RowBox[{"ordered", " ", "=", " ", 
        RowBox[{"SortBy", "[", 
         RowBox[{"reachable", ",", " ", 
          RowBox[{
           RowBox[{"distances", "[", "#", "]"}], " ", "&"}]}], "]"}]}], ";", 
       "\n", "\n", "  ", 
       RowBox[{"sigma", " ", "=", " ", 
        RowBox[{"AssociationThread", "[", 
         RowBox[{"vertices", ",", " ", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0", ",", " ", 
            RowBox[{"Length", "[", "vertices", "]"}]}], "]"}]}], "]"}]}], ";",
        "\n", "  ", 
       RowBox[{
        RowBox[{"sigma", "[", "source", "]"}], " ", "=", " ", "1"}], ";", 
       "\n", "\n", "  ", 
       RowBox[{"Do", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"v", " ", "=!=", " ", "source"}], ",", "\n", "      ", 
           RowBox[{
            RowBox[{"predecessors", " ", "=", " ", 
             RowBox[{"Select", "[", "\n", "        ", 
              RowBox[{
               RowBox[{"Lookup", "[", 
                RowBox[{"adjacencyAssociation", ",", " ", "v", ",", " ", 
                 RowBox[{"{", "}"}]}], "]"}], ",", "\n", "        ", 
               RowBox[{
                RowBox[{
                 RowBox[{"KeyExistsQ", "[", 
                  RowBox[{"distances", ",", " ", "#"}], "]"}], " ", "&&", 
                 "\n", "          ", 
                 RowBox[{"NumericQ", "[", 
                  RowBox[{"distances", "[", "#", "]"}], "]"}], " ", "&&", 
                 "\n", "          ", 
                 RowBox[{
                  RowBox[{"distances", "[", "#", "]"}], " ", "==", " ", 
                  RowBox[{
                   RowBox[{"distances", "[", "v", "]"}], " ", "-", " ", 
                   "1"}]}]}], " ", "&"}]}], "\n", "      ", "]"}]}], ";", 
            "\n", "      ", 
            RowBox[{
             RowBox[{"sigma", "[", "v", "]"}], " ", "=", " ", 
             RowBox[{"Total", "[", 
              RowBox[{"Lookup", "[", 
               RowBox[{"sigma", ",", " ", "predecessors", ",", " ", "0"}], 
               "]"}], "]"}]}], ";"}]}], "\n", "    ", "]"}], ",", "\n", 
         "    ", 
         RowBox[{"{", 
          RowBox[{"v", ",", " ", "ordered"}], "}"}]}], "\n", "  ", "]"}], ";",
        "\n", "\n", "  ", "sigma"}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"sourceDiagnostics", "[", "\n", "   ", 
     RowBox[{
     "g_Graph", ",", "\n", "   ", "source_", ",", "\n", "   ", 
      "adjacencyAssociation_Association", ",", "\n", "   ", 
      RowBox[{"rg_Integer", " ", ":", " ", "fixedGraphShellRadius"}]}], "\n", 
     "   ", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "vertices", ",", " ", "distances", ",", " ", "reachable", ",", " ", 
        "shellVertices", ",", " ", "shellSize", ",", "\n", "   ", "sigma", ",",
         " ", "logSigma", ",", " ", "cLog", ",", " ", "meanLogMultiplicity", ",",
         " ", "stdLogMultiplicity", ",", "\n", "   ", "degree", ",", " ", 
        "clustering"}], "}"}], ",", "\n", "\n", "  ", 
      RowBox[{
       RowBox[{"vertices", " ", "=", " ", 
        RowBox[{"DeleteCases", "[", 
         RowBox[{
          RowBox[{"VertexList", "[", "g", "]"}], ",", " ", "source"}], 
         "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"distances", " ", "=", " ", 
        RowBox[{"AssociationThread", "[", "\n", "    ", 
         RowBox[{"vertices", ",", "\n", "    ", 
          RowBox[{
           RowBox[{
            RowBox[{"GraphDistance", "[", 
             RowBox[{"g", ",", " ", "source", ",", " ", "#"}], "]"}], " ", 
            "&"}], " ", "/@", " ", "vertices"}]}], "\n", "  ", "]"}]}], ";", 
       "\n", "\n", "  ", 
       RowBox[{"reachable", " ", "=", " ", 
        RowBox[{"Select", "[", "\n", "    ", 
         RowBox[{"vertices", ",", "\n", "    ", 
          RowBox[{
           RowBox[{
            RowBox[{"NumericQ", "[", 
             RowBox[{"distances", "[", "#", "]"}], "]"}], " ", "&&", " ", 
            RowBox[{
             RowBox[{"distances", "[", "#", "]"}], " ", "<", " ", 
             "Infinity"}]}], " ", "&"}]}], "\n", "  ", "]"}]}], ";", "\n", 
       "\n", "  ", 
       RowBox[{"shellVertices", " ", "=", " ", 
        RowBox[{"Select", "[", 
         RowBox[{"reachable", ",", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"distances", "[", "#", "]"}], " ", "==", " ", "rg"}], " ",
            "&"}]}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"shellSize", " ", "=", " ", 
        RowBox[{"Length", "[", "shellVertices", "]"}]}], ";", "\n", "\n", 
       "  ", 
       RowBox[{"sigma", " ", "=", " ", 
        RowBox[{"shortestPathCountsFromSource", "[", 
         RowBox[{"g", ",", " ", "source", ",", " ", "adjacencyAssociation"}], 
         "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"logSigma", " ", "=", " ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"shellSize", " ", ">", " ", "0"}], ",", "\n", "    ", 
          RowBox[{"Log", "[", 
           RowBox[{"N", "[", 
            RowBox[{"Lookup", "[", 
             RowBox[{"sigma", ",", " ", "shellVertices"}], "]"}], "]"}], 
           "]"}], ",", "\n", "    ", 
          RowBox[{"{", "}"}]}], "\n", "  ", "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"cLog", " ", "=", " ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "logSigma", "]"}], " ", ">", " ", "1"}], ",",
           "\n", "    ", 
          RowBox[{
           RowBox[{"Mean", "[", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"logSigma", " ", "-", " ", 
               RowBox[{"Mean", "[", "logSigma", "]"}]}], "]"}], "^", "3"}], 
            "]"}], "^", 
           RowBox[{"(", 
            RowBox[{"1", "/", "3"}], ")"}]}], ",", "\n", "    ", "0."}], "\n",
          "  ", "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"meanLogMultiplicity", " ", "=", " ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "logSigma", "]"}], " ", ">", " ", "0"}], ",",
           "\n", "    ", 
          RowBox[{"Mean", "[", "logSigma", "]"}], ",", "\n", "    ", 
          RowBox[{"Missing", "[", "\"\<EmptyShell\>\"", "]"}]}], "\n", "  ", 
         "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"stdLogMultiplicity", " ", "=", " ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "logSigma", "]"}], " ", ">", " ", "1"}], ",",
           "\n", "    ", 
          RowBox[{"StandardDeviation", "[", "logSigma", "]"}], ",", "\n", 
          "    ", "0."}], "\n", "  ", "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"degree", " ", "=", " ", 
        RowBox[{"VertexDegree", "[", 
         RowBox[{"g", ",", " ", "source"}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"clustering", " ", "=", " ", 
        RowBox[{"localClusteringCoefficient", "[", 
         RowBox[{"g", ",", " ", "source"}], "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"<|", "\n", "   ", 
        RowBox[{
         RowBox[{"\"\<GraphShellRadius\>\"", " ", "->", " ", 
          RowBox[{"N", "[", "rg", "]"}]}], ",", "\n", "   ", 
         RowBox[{"\"\<CLog\>\"", " ", "->", " ", 
          RowBox[{"N", "[", "cLog", "]"}]}], ",", "\n", "   ", 
         RowBox[{"\"\<MeanShellSize\>\"", " ", "->", " ", 
          RowBox[{"N", "[", "shellSize", "]"}]}], ",", "\n", "   ", 
         RowBox[{"\"\<StdShellSize\>\"", " ", "->", " ", "0."}], ",", "\n", 
         "   ", 
         RowBox[{"\"\<MeanLogShellSize\>\"", " ", "->", " ", 
          RowBox[{"N", "[", 
           RowBox[{"Log", "[", 
            RowBox[{"1", " ", "+", " ", "shellSize"}], "]"}], "]"}]}], ",", 
         "\n", "   ", 
         RowBox[{"\"\<StdLogShellSize\>\"", " ", "->", " ", "0."}], ",", "\n",
          "   ", 
         RowBox[{"\"\<MeanLogMultiplicityByShell\>\"", " ", "->", " ", 
          RowBox[{"N", "[", "meanLogMultiplicity", "]"}]}], ",", "\n", "   ", 
         RowBox[{"\"\<StdLogMultiplicityByShell\>\"", " ", "->", " ", 
          RowBox[{"N", "[", "stdLogMultiplicity", "]"}]}], ",", "\n", "   ", 
         RowBox[{"\"\<Degree\>\"", " ", "->", " ", 
          RowBox[{"N", "[", "degree", "]"}]}], ",", "\n", "   ", 
         RowBox[{"\"\<ClusteringCoefficient\>\"", " ", "->", " ", 
          RowBox[{"N", "[", "clustering", "]"}]}]}], "\n", "   ", "|>"}]}]}], 
     "\n", "  ", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"diagnosticsForGraph", "[", 
    RowBox[{"data_Association", ",", " ", "nBins_Integer", ",", " ", 
     RowBox[{"maxPerBin_", ":", " ", "All"}]}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "g", ",", " ", "name", ",", " ", "radiusAssociation", ",", " ", 
       "binAssociation", ",", " ", "refs", ",", "\n", "   ", 
       "adjacencyAssociation", ",", " ", "rows"}], "}"}], ",", "\n", "\n", 
     "  ", 
     RowBox[{
      RowBox[{"name", " ", "=", " ", 
       RowBox[{"data", "[", "\"\<Name\>\"", "]"}]}], ";", "\n", "  ", 
      RowBox[{"g", " ", "=", " ", 
       RowBox[{"data", "[", "\"\<Graph\>\"", "]"}]}], ";", "\n", "  ", 
      RowBox[{"radiusAssociation", " ", "=", " ", 
       RowBox[{"data", "[", "\"\<RadiusAssociation\>\"", "]"}]}], ";", "\n", 
      "\n", "  ", 
      RowBox[{"binAssociation", " ", "=", " ", 
       RowBox[{"makeRadialBinAssociation", "[", 
        RowBox[{"radiusAssociation", ",", " ", "nBins"}], "]"}]}], ";", "\n", 
      "  ", 
      RowBox[{"refs", " ", "=", " ", 
       RowBox[{"selectReferenceVertices", "[", 
        RowBox[{
        "radiusAssociation", ",", " ", "nBins", ",", " ", "maxPerBin"}], 
        "]"}]}], ";", "\n", "\n", "  ", 
      RowBox[{"adjacencyAssociation", " ", "=", " ", 
       RowBox[{"AssociationThread", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"VertexList", "[", "g", "]"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{
           RowBox[{"AdjacencyList", "[", 
            RowBox[{"g", ",", " ", "#"}], "]"}], " ", "&"}], " ", "/@", " ", 
          RowBox[{"VertexList", "[", "g", "]"}]}]}], "\n", "  ", "]"}]}], ";",
       "\n", "\n", "  ", 
      RowBox[{"rows", " ", "=", " ", 
       RowBox[{"Table", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Join", "[", "\n", "      ", 
          RowBox[{
           RowBox[{"<|", "\n", "        ", 
            RowBox[{
             RowBox[{"\"\<GraphName\>\"", " ", "->", " ", "name"}], ",", "\n",
              "        ", 
             RowBox[{"\"\<GraphConstruction\>\"", " ", "->", " ", 
              RowBox[{"data", "[", "\"\<GraphConstruction\>\"", "]"}]}], ",", 
             "\n", "        ", 
             RowBox[{"\"\<SourceVertex\>\"", " ", "->", " ", "v"}], ",", "\n",
              "        ", 
             RowBox[{"\"\<Radius\>\"", " ", "->", " ", 
              RowBox[{"N", "[", 
               RowBox[{"radiusAssociation", "[", "v", "]"}], "]"}]}], ",", 
             "\n", "        ", 
             RowBox[{"\"\<RadialBin\>\"", " ", "->", " ", 
              RowBox[{"N", "[", 
               RowBox[{"binAssociation", "[", "v", "]"}], "]"}]}]}], "\n", 
            "      ", "|>"}], ",", "\n", "      ", 
           RowBox[{"sourceDiagnostics", "[", 
            RowBox[{
            "g", ",", " ", "v", ",", " ", "adjacencyAssociation", ",", " ", 
             "fixedGraphShellRadius"}], "]"}]}], "\n", "    ", "]"}], ",", 
         "\n", "    ", 
         RowBox[{"{", 
          RowBox[{"v", ",", " ", "refs"}], "}"}]}], "\n", "  ", "]"}]}], ";", 
      "\n", "\n", "  ", "rows"}]}], "\n", "]"}]}], ";"}], "\n"}], "Input"],

Cell["7. Aggregation helpers", "Section"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "\n", "  ", 
    RowBox[{
    "numericValues", ",", "\n", "  ", "meanOrMissing", ",", "\n", "  ", 
     "sdOrZero", ",", "\n", "  ", "aggregateRowsByGraphAndBin", ",", "\n", 
     "  ", "numericizeRows"}], "\n", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"numericValues", "[", "x_List", "]"}], " ", ":=", " ", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"N", "[", "x", "]"}], ",", " ", "NumericQ"}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"meanOrMissing", "[", "x_List", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "vals", "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"vals", " ", "=", " ", 
        RowBox[{"numericValues", "[", "x", "]"}]}], ";", "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "vals", "]"}], " ", ">", " ", "0"}], ",", 
         " ", 
         RowBox[{"N", "[", 
          RowBox[{"Mean", "[", "vals", "]"}], "]"}], ",", " ", 
         RowBox[{"Missing", "[", "\"\<NoNumericData\>\"", "]"}]}], "]"}]}]}], 
     "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"sdOrZero", "[", "x_List", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "vals", "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"vals", " ", "=", " ", 
        RowBox[{"numericValues", "[", "x", "]"}]}], ";", "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "vals", "]"}], " ", ">", " ", "1"}], ",", 
         " ", 
         RowBox[{"N", "[", 
          RowBox[{"StandardDeviation", "[", "vals", "]"}], "]"}], ",", " ", 
         "0."}], "]"}]}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"aggregateRowsByGraphAndBin", "[", "rows_List", "]"}], " ", ":=", 
    " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"groups", ",", " ", "diagnosticKeys"}], "}"}], ",", "\n", "\n",
       "  ", 
      RowBox[{
       RowBox[{"diagnosticKeys", " ", "=", " ", 
        RowBox[{"{", "\n", "    ", 
         RowBox[{"\"\<CLog\>\"", ",", "\n", "    ", "\"\<MeanShellSize\>\"", ",",
           "\n", "    ", "\"\<StdShellSize\>\"", ",", "\n", 
          "    ", "\"\<MeanLogShellSize\>\"", ",", "\n", 
          "    ", "\"\<StdLogShellSize\>\"", ",", "\n", 
          "    ", "\"\<MeanLogMultiplicityByShell\>\"", ",", "\n", 
          "    ", "\"\<StdLogMultiplicityByShell\>\"", ",", "\n", 
          "    ", "\"\<Degree\>\"", ",", "\n", 
          "    ", "\"\<ClusteringCoefficient\>\""}], "\n", "  ", "}"}]}], ";",
        "\n", "\n", "  ", 
       RowBox[{"groups", " ", "=", " ", 
        RowBox[{
         RowBox[{"Values", " ", "@", " ", 
          RowBox[{"GroupBy", "[", 
           RowBox[{"rows", ",", " ", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"#", "[", "\"\<GraphName\>\"", "]"}], ",", " ", 
               RowBox[{"#", "[", "\"\<RadialBin\>\"", "]"}]}], "}"}], " ", 
             "&"}]}], "]"}]}], " ", "/.", " ", 
         RowBox[{
          RowBox[{"Key", "[", "x_", "]"}], " ", ":>", " ", "x"}]}]}], ";", 
       "\n", "\n", "  ", 
       RowBox[{"Table", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Association", "[", "\n", "      ", 
          RowBox[{"Flatten", "[", "\n", "        ", 
           RowBox[{"{", "\n", "          ", 
            RowBox[{
             RowBox[{"\"\<GraphName\>\"", " ", "->", " ", 
              RowBox[{
               RowBox[{"First", "[", "group", "]"}], "[", "\"\<GraphName\>\"",
                "]"}]}], ",", "\n", "          ", 
             RowBox[{"\"\<GraphConstruction\>\"", " ", "->", " ", 
              RowBox[{
               RowBox[{"First", "[", "group", "]"}], 
               "[", "\"\<GraphConstruction\>\"", "]"}]}], ",", "\n", 
             "          ", 
             RowBox[{"\"\<RadialBin\>\"", " ", "->", " ", 
              RowBox[{
               RowBox[{"First", "[", "group", "]"}], "[", "\"\<RadialBin\>\"",
                "]"}]}], ",", "\n", "          ", 
             RowBox[{"\"\<RadiusMean\>\"", " ", "->", " ", 
              RowBox[{"N", "[", 
               RowBox[{"Mean", "[", 
                RowBox[{"Lookup", "[", 
                 RowBox[{"group", ",", " ", "\"\<Radius\>\""}], "]"}], "]"}], 
               "]"}]}], ",", "\n", "          ", 
             RowBox[{"\"\<NReferenceVertices\>\"", " ", "->", " ", 
              RowBox[{"Length", "[", "group", "]"}]}], ",", "\n", "\n", 
             "          ", 
             RowBox[{"Table", "[", "\n", "            ", 
              RowBox[{
               RowBox[{"{", "\n", "              ", 
                RowBox[{
                 RowBox[{
                  RowBox[{"key", " ", "<>", " ", "\"\<_Mean\>\""}], " ", "->",
                   " ", 
                  RowBox[{"meanOrMissing", "[", 
                   RowBox[{"Lookup", "[", 
                    RowBox[{"group", ",", " ", "key"}], "]"}], "]"}]}], ",", 
                 "\n", "              ", 
                 RowBox[{
                  RowBox[{"key", " ", "<>", " ", "\"\<_SD\>\""}], " ", "->", 
                  " ", 
                  RowBox[{"sdOrZero", "[", 
                   RowBox[{"Lookup", "[", 
                    RowBox[{"group", ",", " ", "key"}], "]"}], "]"}]}]}], 
                "\n", "            ", "}"}], ",", "\n", "            ", 
               RowBox[{"{", 
                RowBox[{"key", ",", " ", "diagnosticKeys"}], "}"}]}], "\n", 
              "          ", "]"}]}], "\n", "        ", "}"}], "\n", "      ", 
           "]"}], "\n", "    ", "]"}], ",", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{"group", ",", " ", "groups"}], "}"}]}], "\n", "  ", 
        "]"}]}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"numericizeRows", "[", "rows_List", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Association", " ", "@", " ", 
       RowBox[{"KeyValueMap", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"#1", " ", "->", " ", 
           RowBox[{"Quiet", "@", 
            RowBox[{"Check", "[", 
             RowBox[{
              RowBox[{"N", "[", "#2", "]"}], ",", " ", "#2"}], "]"}]}]}], " ",
           "&"}], ",", " ", "#"}], "]"}]}], ")"}], " ", "&"}], " ", "/@", " ",
     "rows"}]}], ";"}], "\n"}], "Input"],

Cell["8. Checkpointed execution", "Section"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "runOneGraphCheckpoint", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"runOneGraphCheckpoint", "[", 
    RowBox[{
    "data_Association", ",", " ", "nBins_Integer", ",", " ", "maxPerBin_"}], 
    "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "name", ",", " ", "refTag", ",", " ", "sourceFile", ",", " ", 
       "binnedFile", ",", " ", "time", ",", " ", "rows", ",", " ", 
       "binnedRows"}], "}"}], ",", "\n", "\n", "  ", 
     RowBox[{
      RowBox[{"name", " ", "=", " ", 
       RowBox[{"data", "[", "\"\<Name\>\"", "]"}]}], ";", "\n", "  ", 
      RowBox[{"refTag", " ", "=", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"maxPerBin", " ", "===", " ", "All"}], ",", 
         " ", "\"\<refsAll\>\"", ",", " ", 
         RowBox[{"\"\<refsPerBin\>\"", " ", "<>", " ", 
          RowBox[{"ToString", "[", "maxPerBin", "]"}]}]}], "]"}]}], ";", "\n",
       "\n", "  ", 
      RowBox[{"sourceFile", " ", "=", " ", 
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{"checkpointDir", ",", " ", 
          RowBox[{
          "name", " ", "<>", " ", "\"\<_\>\"", " ", "<>", " ", "refTag", " ", 
           "<>", " ", "\"\<_sourceRows.mx\>\""}]}], "}"}], "]"}]}], ";", "\n",
       "  ", 
      RowBox[{"binnedFile", " ", "=", " ", 
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{"checkpointDir", ",", " ", 
          RowBox[{
          "name", " ", "<>", " ", "\"\<_\>\"", " ", "<>", " ", "refTag", " ", 
           "<>", " ", "\"\<_binnedRows.mx\>\""}]}], "}"}], "]"}]}], ";", "\n",
       "\n", "  ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"FileExistsQ", "[", "sourceFile", "]"}], " ", "&&", " ", 
         RowBox[{"FileExistsQ", "[", "binnedFile", "]"}]}], ",", "\n", "    ", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"\"\<Already exists, loading: \>\"", ",", " ", "name"}], 
          "]"}], ";", "\n", "    ", 
         RowBox[{"Return", "[", "\n", "      ", 
          RowBox[{"<|", "\n", "        ", 
           RowBox[{
            RowBox[{"\"\<Name\>\"", " ", "->", " ", "name"}], ",", "\n", 
            "        ", 
            RowBox[{"\"\<SourceRows\>\"", " ", "->", " ", 
             RowBox[{"Import", "[", "sourceFile", "]"}]}], ",", "\n", 
            "        ", 
            RowBox[{"\"\<BinnedRows\>\"", " ", "->", " ", 
             RowBox[{"Import", "[", "binnedFile", "]"}]}]}], "\n", "      ", 
           "|>"}], "\n", "    ", "]"}], ";"}]}], "\n", "  ", "]"}], ";", "\n",
       "\n", "  ", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Running diagnostics for: \>\"", ",", " ", "name"}], "]"}],
       ";", "\n", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"time", ",", " ", "rows"}], "}"}], " ", "=", " ", 
       RowBox[{"AbsoluteTiming", "[", "\n", "    ", 
        RowBox[{"CheckAbort", "[", "\n", "      ", 
         RowBox[{
          RowBox[{"diagnosticsForGraph", "[", 
           RowBox[{"data", ",", " ", "nBins", ",", " ", "maxPerBin"}], "]"}], 
          ",", "\n", "      ", "$Aborted"}], "\n", "    ", "]"}], "\n", "  ", 
        "]"}]}], ";", "\n", "\n", "  ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"rows", " ", "===", " ", "$Aborted"}], " ", "||", " ", 
         RowBox[{"rows", " ", "===", " ", "$Failed"}]}], ",", "\n", "    ", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"\"\<FAILED or aborted: \>\"", ",", " ", "name"}], "]"}], ";",
          "\n", "    ", 
         RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], "\n", "  ", "]"}], 
      ";", "\n", "\n", "  ", 
      RowBox[{"rows", " ", "=", " ", 
       RowBox[{"numericizeRows", "[", "rows", "]"}]}], ";", "\n", "\n", "  ", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Finished \>\"", ",", " ", "name", ",", " ", "\"\< in \>\"",
         ",", " ", 
        RowBox[{"NumberForm", "[", 
         RowBox[{
          RowBox[{"time", "/", "60"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"5", ",", " ", "2"}], "}"}]}], "]"}], ",", 
        " ", "\"\< minutes.\>\""}], "]"}], ";", "\n", "\n", "  ", 
      RowBox[{"Export", "[", 
       RowBox[{"sourceFile", ",", " ", "rows"}], "]"}], ";", "\n", "\n", "  ", 
      RowBox[{"binnedRows", " ", "=", " ", 
       RowBox[{"numericizeRows", "[", 
        RowBox[{"aggregateRowsByGraphAndBin", "[", "rows", "]"}], "]"}]}], ";",
       "\n", "\n", "  ", 
      RowBox[{"Export", "[", 
       RowBox[{"binnedFile", ",", " ", "binnedRows"}], "]"}], ";", "\n", "\n",
       "  ", 
      RowBox[{"<|", "\n", "    ", 
       RowBox[{
        RowBox[{"\"\<Name\>\"", " ", "->", " ", "name"}], ",", "\n", "    ", 
        RowBox[{"\"\<SourceRows\>\"", " ", "->", " ", "rows"}], ",", "\n", 
        "    ", 
        RowBox[{"\"\<BinnedRows\>\"", " ", "->", " ", "binnedRows"}]}], "\n", 
       "  ", "|>"}]}]}], "\n", "]"}]}], ";"}], "\n"}], "Input"],

Cell["9. Smoke test on Schwarzschild/Flamm", "Section"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"smokeMaxRefsPerBin", " ", "=", " ", "5"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"smokeFlamm", " ", "=", " ", 
    RowBox[{"runOneGraphCheckpoint", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"SelectFirst", "[", 
       RowBox[{"allGraphData", ",", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "[", "\"\<Name\>\"", "]"}], " ", "==", 
          " ", "\"\<SchwarzschildFlamm\>\""}], " ", "&"}]}], "]"}], ",", "\n",
       "  ", "nRadialBins", ",", "\n", "  ", "smokeMaxRefsPerBin"}], "\n", 
     "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"Dataset", "[", 
  RowBox[{"smokeFlamm", "[", "\"\<BinnedRows\>\"", "]"}], 
  "]"}], "\n"}], "Input"],

Cell["10. Full run", "Section"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Run", " ", "this", " ", "after", " ", "the", " ", "smoke", " ", "test", " ",
      "looks", " ", 
     RowBox[{"reasonable", ".", " ", "With"}], " ", "maxRefsPerBin"}], " ", "=",
     " ", 
